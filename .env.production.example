# ==============================================================================
# TAURO PRODUCTION ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env.local (for development) or set in Vercel dashboard
# (for production). All NEXT_PUBLIC_* vars are exposed to the browser.
# ==============================================================================

# --- Site Configuration ---
NEXT_PUBLIC_SITE_URL=https://taurorealty.com   # Production domain (SEO, OG tags, sitemaps)

# --- Supabase (Database & Auth) ---
NEXT_PUBLIC_SUPABASE_URL=                       # Supabase project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=                  # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=                       # Supabase service role key (server-side only, NEVER expose)

# --- GoHighLevel (CRM Integration) ---
GHL_WEBHOOK_URL=                                 # GHL inbound webhook URL for contact creation
GHL_API_KEY=                                     # GHL API v2 key (optional, enables API-based sync)
GHL_LOCATION_ID=                                 # GHL location/sub-account ID (required if using API key)
GHL_WEBHOOK_SECRET=                              # HMAC secret for verifying inbound GHL webhooks

# --- Email (Resend) ---
RESEND_API_KEY=                                  # Resend API key (https://resend.com/api-keys)
EMAIL_FROM=noreply@taurorealty.com               # Sender email address for transactional emails
ADMIN_EMAIL=julian@aiacrobatics.com              # Admin notification email for new leads

# --- Mapbox (Property Maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN=                        # Mapbox public access token (https://account.mapbox.com/access-tokens/)

# --- Cloudflare Turnstile (CAPTCHA) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=                  # Turnstile site key (https://dash.cloudflare.com/turnstile)
TURNSTILE_SECRET_KEY=                            # Turnstile secret key (server-side verification)

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=                   # GA4 measurement ID (G-XXXXXXXXXX)

# --- Sentry (optional) ---
SENTRY_DSN=                                      # Sentry DSN for error reporting
SENTRY_AUTH_TOKEN=                               # Sentry auth token (for source map uploads during build)

# --- Cron ---
CRON_SECRET=                                     # Secret for authenticating cron job endpoints

# --- Upload Security ---
UPLOAD_API_KEY=                                  # API key for /api/upload endpoint (set to a random string)
